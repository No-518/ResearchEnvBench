ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY>

# Recommended for paper-aligned runs.
CLAUDE_MODEL=glm-4.7

