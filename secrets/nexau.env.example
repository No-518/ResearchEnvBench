# Paper baseline: nexau (DeepSeek-V3.1-Nex-N1 through NexAU framework)
# Fill these values before running.

LLM_MODEL=nex-agi/deepseek-v3.1-nex-1
LLM_BASE_URL=<YOUR_DEEPSEEK_BASE_URL>
LLM_API_KEY=<YOUR_DEEPSEEK_API_KEY>

# Defaults in release runner are anthropic_* to match official NexAU DeepSeek config.
# If your endpoint is OpenAI-compatible, override both to openai_*.
LLM_API_TYPE=anthropic_chat_completion
LLM_TOOL_CALL_MODE=anthropic

# Optional: pin official NexAU config explicitly (default for `nexau` backend).
# NEXAU_AGENT_CONFIG=/opt/nexau/env_setup_config/deepseek-v3.1-nex-n1.yaml
