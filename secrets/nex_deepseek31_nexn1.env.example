# NexAU backend: nexau_deepseek31_nexn1
# Fill all placeholders before smoke/full runs.

LLM_MODEL=deepseek-v3.1
LLM_BASE_URL=<YOUR_DEEPSEEK_BASE_URL>
LLM_API_KEY=<YOUR_DEEPSEEK_API_KEY>
LLM_API_TYPE=anthropic_chat_completion
LLM_TOOL_CALL_MODE=anthropic

# If your DeepSeek endpoint is OpenAI-compatible, switch to:
# LLM_API_TYPE=openai_chat_completion
# LLM_TOOL_CALL_MODE=openai

# Optional: choose which NexAU agent YAML to use.
# 1) Official built-in NexAU DeepSeek config:
# NEXAU_AGENT_CONFIG=/opt/nexau/env_setup_config/deepseek-v3.1-nex-n1.yaml
# 2) Harness custom DeepSeek config (editable in this repo):
# NEXAU_AGENT_CONFIG=/opt/scimlopsbench/harness/tools/env_setup_runner/nexau_configs/nexau_deepseek31_nexn1.yaml

SUMMARY_MODEL=<OPTIONAL_SUMMARY_MODEL>
SUMMARY_BASE_URL=<OPTIONAL_SUMMARY_BASE_URL>
SUMMARY_API_KEY=<OPTIONAL_SUMMARY_API_KEY>

EXTRACT_MODEL=<OPTIONAL_EXTRACT_MODEL>
EXTRACT_BASE_URL=<OPTIONAL_EXTRACT_BASE_URL>
EXTRACT_API_KEY=<OPTIONAL_EXTRACT_API_KEY>

LANGFUSE_SECRET_KEY=<OPTIONAL_LANGFUSE_SECRET_KEY>
LANGFUSE_PUBLIC_KEY=<OPTIONAL_LANGFUSE_PUBLIC_KEY>
LANGFUSE_HOST=<OPTIONAL_LANGFUSE_HOST>
LANGFUSE_BASE_URL=<OPTIONAL_LANGFUSE_BASE_URL>
