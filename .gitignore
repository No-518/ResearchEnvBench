# Ignore a local root-level Dockerfile if you keep one around.
/nex.Dockerfile
.sii/

# Downloaded repos / runtime logs (large, machine-local)
/repos/
/logs/

# Benchmark artifacts (generated by benchmark_scripts/*, e.g. run_all.sh + prepare_assets.sh)
**/build_output/
**/benchmark_assets/

# Python virtualenvs + caches
**/.venv/
**/venv/
**/__pycache__/
**/*.py[cod]
**/*.egg-info/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.pyright/

# Coverage / reports
**/.coverage
**/coverage.xml
**/htmlcov/
**/mypy_reports/

# Node / JS
**/node_modules/

# Secrets / local env files
.env
.env.*
!.env.example
secrets/*
!secrets/*.env.example

# Machine-local data (never commit)
results/
